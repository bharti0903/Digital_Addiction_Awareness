<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Limits & Notifications</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">

  <%- include("../partials/navbar") %>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">Limits & Notifications</h1>
      <p class="text-slate-600">Monitor your usage against your personalized thresholds.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-6 mb-8">
      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-sm font-semibold text-slate-500 uppercase mb-2">Today</h2>
        <p class="text-3xl font-bold text-blue-600"><%= todayTotal %> hrs</p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-sm font-semibold text-slate-500 uppercase mb-2">Daily Limit</h2>
        <p class="text-3xl font-bold text-indigo-600"><%= dailyLimit %> hrs</p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-sm font-semibold text-slate-500 uppercase mb-2">Warning</h2>
        <p class="text-3xl font-bold text-yellow-600"><%= warningLimit %> hrs</p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-sm font-semibold text-slate-500 uppercase mb-2">Danger</h2>
        <p class="text-3xl font-bold text-red-600"><%= dangerLimit %> hrs</p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6">
        <h2 class="text-sm font-semibold text-slate-500 uppercase mb-2">Status</h2>
        <p class="text-2xl font-bold <%= limitStatus === 'Healthy' ? 'text-green-600' : limitStatus === 'Approaching Limit' ? 'text-yellow-600' : 'text-red-600' %>">
          <%= limitStatus %>
        </p>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow p-6 mb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-2xl font-bold">Today’s Limit Progress</h2>
        <span class="text-sm font-semibold text-slate-600"><%= progressPercent %>%</span>
      </div>

      <div class="w-full bg-slate-200 rounded-full h-4 overflow-hidden">
        <div
          class="h-4 rounded-full <%= limitStatus === 'Healthy' ? 'bg-green-500' : limitStatus === 'Approaching Limit' ? 'bg-yellow-500' : 'bg-red-500' %>"
          style="width:<%= progressPercent %>%"
        ></div>
      </div>

      <div class="flex flex-wrap gap-3 mt-4">
        <% if (alerts && alerts.length > 0 && unreadCount > 0) { %>
          <form action="/smart-alerts/read-all" method="POST">
            <button type="submit" class="px-4 py-2 rounded-lg bg-green-600 text-white font-semibold hover:bg-green-700 transition">
              Mark All Read
            </button>
          </form>
        <% } %>
        <a href="/profile-settings" class="px-4 py-2 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 transition">
          Edit Limits
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-2xl shadow p-6 border border-slate-200">
        <h2 class="text-sm font-semibold text-slate-500 uppercase mb-2">Total Alerts</h2>
        <p class="text-3xl font-bold text-slate-900"><%= totalCount %></p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6 border border-slate-200">
        <h2 class="text-sm font-semibold text-slate-500 uppercase mb-2">Unread</h2>
        <p class="text-3xl font-bold text-indigo-700"><%= unreadCount %></p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6 border border-slate-200">
        <h2 class="text-sm font-semibold text-slate-500 uppercase mb-2">Warnings / Danger</h2>
        <p class="text-3xl font-bold text-red-600"><%= dangerCount + warningCount %></p>
      </div>

      <div class="bg-white rounded-2xl shadow p-6 border border-slate-200">
        <h2 class="text-sm font-semibold text-slate-500 uppercase mb-2">Info</h2>
        <p class="text-3xl font-bold text-sky-600"><%= infoCount %></p>
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow border border-slate-200 p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900">Recent Notifications</h2>
        <% if (unreadCount > 0) { %>
          <span class="px-3 py-1 rounded-full bg-red-100 text-red-700 text-sm font-semibold">
            <%= unreadCount %> unread
          </span>
        <% } %>
      </div>

      <% if (alerts && alerts.length > 0) { %>
        <div class="space-y-4">
          <% alerts.forEach(alert => { %>
            <div class="rounded-2xl border p-5 transition hover:shadow-md
              <%= alert.type === 'danger' ? 'bg-red-50 border-red-200' : '' %>
              <%= alert.type === 'warning' ? 'bg-yellow-50 border-yellow-200' : '' %>
              <%= alert.type === 'info' ? 'bg-blue-50 border-blue-200' : '' %>
              <%= alert.isRead ? 'opacity-80' : 'ring-1 ring-offset-1 ring-slate-200' %>
            ">
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                <div>
                  <div class="flex flex-wrap items-center gap-2 mb-2">
                    <h3 class="font-bold text-slate-900"><%= alert.message %></h3>

                    <span class="text-xs px-3 py-1 rounded-full font-semibold
                      <%= alert.type === 'danger' ? 'bg-red-100 text-red-700' : '' %>
                      <%= alert.type === 'warning' ? 'bg-yellow-100 text-yellow-700' : '' %>
                      <%= alert.type === 'info' ? 'bg-blue-100 text-blue-700' : '' %>
                    ">
                      <%= alert.type %>
                    </span>

                    <% if (!alert.isRead) { %>
                      <span class="text-xs px-3 py-1 rounded-full bg-indigo-100 text-indigo-700 font-semibold">
                        Unread
                      </span>
                    <% } else { %>
                      <span class="text-xs px-3 py-1 rounded-full bg-slate-100 text-slate-600 font-semibold">
                        Read
                      </span>
                    <% } %>
                  </div>

                  <p class="text-sm text-slate-500">
                    <%= new Date(alert.createdAt).toLocaleString() %>
                  </p>
                </div>

                <% if (!alert.isRead) { %>
                  <form action="/smart-alerts/read/<%= alert._id %>" method="POST">
                    <button type="submit" class="px-4 py-2 rounded-lg bg-slate-900 text-white font-semibold hover:bg-slate-700 transition">
                      Mark Read
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-slate-500">No notifications yet.</p>
      <% } %>
    </div>
  </div>

  <%- include("../partials/footer") %>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    socket.on("screenTimeUpdated", function () {
      window.location.reload();
    });
  </script>
</body>
</html>