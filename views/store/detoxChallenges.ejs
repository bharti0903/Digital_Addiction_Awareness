<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Goals & Habits</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">

  <%- include("../partials/navbar") %>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">Goals & Habits</h1>
      <p class="text-slate-600">Build healthier digital habits through guided goals.</p>
    </div>

    <% if (error) { %>
      <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-700 border border-red-200">
        <%= error %>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="mb-4 p-4 rounded-lg bg-green-100 text-green-700 border border-green-200">
        <%= success %>
      </div>
    <% } %>

    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">
      <% if (challenges && challenges.length > 0) { %>
        <% challenges.forEach(challenge => { %>
          <%
            const joined = challenge.participants.some(
              p => p.user.toString() === currentUserId.toString()
            );

            const participant = challenge.participants.find(
              p => p.user.toString() === currentUserId.toString()
            );

            const progressDays = participant ? participant.progressDays : 0;
            const completed = participant ? participant.completed : false;
            const progressPercent = Math.min(
              Math.round((progressDays / challenge.targetDays) * 100),
              100
            );
          %>

          <div class="bg-white rounded-3xl shadow border border-slate-200 p-6 flex flex-col justify-between">
            <div>
              <div class="flex items-start justify-between gap-3 mb-4">
                <div>
                  <h2 class="text-xl font-bold text-slate-900"><%= challenge.title %></h2>
                  <p class="text-slate-600 mt-2"><%= challenge.description %></p>
                </div>

                <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center shrink-0">
                  <i class="fas fa-bullseye text-blue-600 text-xl"></i>
                </div>
              </div>

              <div class="space-y-2 mb-5 text-sm">
                <p><strong>Target Days:</strong> <%= challenge.targetDays %></p>
                <p><strong>Participants:</strong> <%= challenge.participants.length %></p>

                <% if (joined) { %>
                  <p><strong>Your Progress:</strong> <%= progressDays %> / <%= challenge.targetDays %> days</p>
                  <p>
                    <strong>Status:</strong>
                    <span class="<%= completed ? 'text-green-600 font-bold' : 'text-yellow-600 font-semibold' %>">
                      <%= completed ? 'Completed' : 'In Progress' %>
                    </span>
                  </p>
                <% } else { %>
                  <p><strong>Status:</strong> <span class="text-slate-500">Not Started</span></p>
                <% } %>
              </div>

              <% if (joined) { %>
                <div class="mb-5">
                  <div class="flex items-center justify-between text-sm mb-2">
                    <span class="font-medium text-slate-700">Progress</span>
                    <span class="font-semibold text-slate-700"><%= progressPercent %>%</span>
                  </div>
                  <div class="w-full bg-slate-200 rounded-full h-3 overflow-hidden">
                    <div
                      class="h-3 rounded-full <%= completed ? 'bg-green-500' : 'bg-indigo-500' %>"
                      style="width:<%= progressPercent %>%"
                    ></div>
                  </div>
                </div>
              <% } %>
            </div>

            <div class="mt-4">
              <% if (!joined) { %>
                <form action="/detox-challenges/join" method="POST">
                  <input type="hidden" name="challengeId" value="<%= challenge._id %>">
                  <button
                    type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-xl font-semibold transition"
                  >
                    Start Goal
                  </button>
                </form>
              <% } else { %>
                <form action="/detox-challenges/progress" method="POST">
                  <input type="hidden" name="challengeId" value="<%= challenge._id %>">
                  <button
                    type="submit"
                    class="w-full py-3 rounded-xl font-semibold text-white transition <%= completed ? 'bg-green-600 cursor-not-allowed' : 'bg-indigo-600 hover:bg-indigo-700' %>"
                    <%= completed ? 'disabled' : '' %>
                  >
                    <%= completed ? 'Goal Completed' : 'Mark Today Complete' %>
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p>No goals available.</p>
      <% } %>
    </div>
  </div>

  <%- include("../partials/footer") %>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    socket.on("screenTimeUpdated", function () {
      window.location.reload();
    });
  </script>
</body>
</html>