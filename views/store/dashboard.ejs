<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">

  <%- include("../partials/navbar") %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">Dashboard</h1>
      <p class="text-slate-600">
        Welcome, <%= userName || "User" %>. Here is your screen-time analytics overview.
      </p>
    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-5 gap-4 mb-8">
      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Today’s Usage</p>
        <p class="text-2xl font-bold text-indigo-700"><%= todayTotal %> hrs</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Time Left</p>
        <p class="text-2xl font-bold text-green-700"><%= timeLeft %> hrs</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Today’s Sessions</p>
        <p class="text-2xl font-bold text-blue-700"><%= todaySessionCount %></p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Most Used Category</p>
        <p class="text-2xl font-bold text-slate-900"><%= mostUsedCategory %></p>
        <p class="text-sm text-slate-500 mt-1"><%= mostUsedCategoryHours %> hrs</p>
      </div>

      <div class="bg-white p-5 rounded-2xl shadow border border-slate-200">
        <p class="text-sm text-slate-500">Usage Status</p>
        <p class="text-2xl font-bold text-red-600"><%= usageStatus %></p>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow border border-slate-200 p-6 mb-8">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-2xl font-bold">Daily Limit Progress</h2>
        <span class="text-sm text-slate-500"><%= progressPercent %>% used</span>
      </div>

      <div class="w-full h-4 bg-slate-200 rounded-full overflow-hidden">
        <div
          class="h-full bg-indigo-600 rounded-full"
          style="width: <%= progressPercent %>%"
        ></div>
      </div>

      <div class="grid md:grid-cols-3 gap-4 mt-4 text-sm text-slate-600">
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-4">
          <p class="font-semibold text-yellow-700">Warning Limit</p>
          <p><%= warningLimit %> hrs</p>
        </div>
        <div class="bg-red-50 border border-red-200 rounded-xl p-4">
          <p class="font-semibold text-red-700">Danger Limit</p>
          <p><%= dangerLimit %> hrs</p>
        </div>
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
          <p class="font-semibold text-blue-700">Daily Limit</p>
          <p><%= dailyLimit %> hrs</p>
        </div>
      </div>
    </div>

    <div class="grid xl:grid-cols-2 gap-8 mb-8">
      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-4">Today’s Category Usage</h2>
        <canvas id="categoryChart"></canvas>
      </div>

      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-4">Last 7 Days Usage</h2>
        <canvas id="weeklyChart"></canvas>
      </div>
    </div>

    <div class="grid xl:grid-cols-2 gap-8 mb-8">
      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-4">Weekly Summary</h2>

        <div class="grid grid-cols-2 gap-4 mb-6">
          <div class="bg-slate-50 border rounded-xl p-4">
            <p class="text-sm text-slate-500">Weekly Total</p>
            <p class="text-2xl font-bold"><%= weeklyTotal %> hrs</p>
          </div>
          <div class="bg-slate-50 border rounded-xl p-4">
            <p class="text-sm text-slate-500">Daily Average</p>
            <p class="text-2xl font-bold"><%= weeklyAverage %> hrs</p>
          </div>
        </div>

        <% if (weeklyBreakdown && weeklyBreakdown.length > 0) { %>
          <div class="space-y-3">
            <% weeklyBreakdown.forEach(day => { %>
              <div class="flex items-center justify-between border rounded-xl p-3">
                <span class="font-medium"><%= day.label %></span>
                <span class="text-slate-600"><%= day.total %> hrs</span>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-slate-500">No weekly data available.</p>
        <% } %>
      </div>

      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-4">Top Distracting Websites</h2>

        <% if (topWebsites && topWebsites.length > 0) { %>
          <div class="space-y-4">
            <% topWebsites.forEach((site, index) => { %>
              <div class="border rounded-xl p-4">
                <div class="flex items-center justify-between mb-2">
                  <p class="font-bold">#<%= index + 1 %> <%= site.domain %></p>
                  <span class="text-sm px-3 py-1 rounded-full bg-slate-100"><%= site.category %></span>
                </div>
                <p class="text-sm text-slate-600 mb-1"><strong>Total Hours:</strong> <%= site.totalHours %></p>
                <p class="text-sm text-slate-600 mb-1"><strong>Visits:</strong> <%= site.visits %></p>
                <p class="text-sm text-slate-600"><strong>Last Title:</strong> <%= site.lastTitle %></p>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-slate-500">No extension website activity yet.</p>
        <% } %>
      </div>
    </div>

    <div class="bg-white rounded-2xl shadow border border-slate-200 p-6 mb-8">
      <h2 class="text-2xl font-bold mb-4">Recent Browser Activity</h2>

      <% if (recentExtensionActivity && recentExtensionActivity.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead>
              <tr class="bg-slate-100 text-left">
                <th class="p-3 border">Domain</th>
                <th class="p-3 border">Title</th>
                <th class="p-3 border">Category</th>
                <th class="p-3 border">Hours</th>
                <th class="p-3 border">Time</th>
              </tr>
            </thead>
            <tbody>
              <% recentExtensionActivity.forEach(item => { %>
                <tr>
                  <td class="p-3 border"><%= item.domain %></td>
                  <td class="p-3 border"><%= item.title %></td>
                  <td class="p-3 border"><%= item.category %></td>
                  <td class="p-3 border"><%= item.hours %></td>
                  <td class="p-3 border"><%= new Date(item.createdAt).toLocaleString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-slate-500">No recent browser activity found.</p>
      <% } %>
    </div>
  </div>

  <%- include("../partials/footer") %>

  <script>
    const categoryLabels = <%- categoryChartLabels %>;
    const categoryData = <%- categoryChartData %>;
    const weeklyLabels = <%- weeklyChartLabels %>;
    const weeklyData = <%- weeklyChartData %>;

    const categoryCtx = document.getElementById("categoryChart").getContext("2d");
    new Chart(categoryCtx, {
      type: "doughnut",
      data: {
        labels: categoryLabels,
        datasets: [
          {
            label: "Hours",
            data: categoryData,
            borderWidth: 1
          }
        ]
      },
      options: {
        responsive: true,
        plugins: {
          legend: {
            position: "bottom"
          }
        }
      }
    });

    const weeklyCtx = document.getElementById("weeklyChart").getContext("2d");
    new Chart(weeklyCtx, {
      type: "bar",
      data: {
        labels: weeklyLabels,
        datasets: [
          {
            label: "Hours",
            data: weeklyData,
            borderWidth: 1
          }
        ]
      },
      options: {
        responsive: true,
        scales: {
          y: {
            beginAtZero: true
          }
        }
      }
    });
  </script>
</body>
</html>