<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Limits & Preferences</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-slate-50 min-h-screen text-slate-800">

  <%- include("../partials/navbar") %>

  <%
    function getHours(value) {
      return Math.floor(value || 0);
    }

    function getMinutes(value) {
      return Math.round(((value || 0) % 1) * 60);
    }

    function formatTime(value) {
      const h = Math.floor(value || 0);
      const m = Math.round(((value || 0) % 1) * 60);
      return `${h}h ${m}m`;
    }
  %>

  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900">Limits & Preferences</h1>
      <p class="text-slate-600">Manage your account details, screen-time thresholds, and password.</p>
    </div>

    <% if (error) { %>
      <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-700 border border-red-200">
        <%= error %>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="mb-4 p-4 rounded-lg bg-green-100 text-green-700 border border-green-200">
        <%= success %>
      </div>
    <% } %>

    <div class="grid lg:grid-cols-2 gap-8">
      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-6">Account & Limits</h2>

        <form action="/profile-settings/update" method="POST" class="grid gap-4">
          <div>
            <label class="block mb-2 font-medium">Full Name</label>
            <input
              type="text"
              name="name"
              value="<%= user.name %>"
              class="w-full border rounded-lg px-4 py-3"
              required
            >
          </div>

          <div>
            <label class="block mb-2 font-medium">Email Address</label>
            <input
              type="email"
              value="<%= user.email %>"
              class="w-full border rounded-lg px-4 py-3 bg-slate-100"
              disabled
            >
          </div>

          <div>
            <label class="block mb-2 font-medium">Daily Limit (hours)</label>
            <input
              type="number"
              name="dailyLimit"
              min="1"
              max="24"
              step="0.1"
              value="<%= user.dailyLimit %>"
              class="w-full border rounded-lg px-4 py-3"
              required
            >
          </div>

          <div>
            <label class="block mb-2 font-medium">Warning Threshold</label>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm text-slate-500 mb-1">Hours</label>
                <input
                  type="number"
                  name="warningHours"
                  min="0"
                  max="24"
                  value="<%= getHours(user.warningLimit) %>"
                  class="w-full border rounded-lg px-4 py-3"
                  required
                >
              </div>
              <div>
                <label class="block text-sm text-slate-500 mb-1">Minutes</label>
                <input
                  type="number"
                  name="warningMinutes"
                  min="0"
                  max="59"
                  value="<%= getMinutes(user.warningLimit) %>"
                  class="w-full border rounded-lg px-4 py-3"
                  required
                >
              </div>
            </div>
            <p class="text-sm text-slate-500 mt-2">
              Current warning threshold: <strong><%= formatTime(user.warningLimit) %></strong>
            </p>
          </div>

          <div>
            <label class="block mb-2 font-medium">Danger Threshold</label>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm text-slate-500 mb-1">Hours</label>
                <input
                  type="number"
                  name="dangerHours"
                  min="0"
                  max="24"
                  value="<%= getHours(user.dangerLimit) %>"
                  class="w-full border rounded-lg px-4 py-3"
                  required
                >
              </div>
              <div>
                <label class="block text-sm text-slate-500 mb-1">Minutes</label>
                <input
                  type="number"
                  name="dangerMinutes"
                  min="0"
                  max="59"
                  value="<%= getMinutes(user.dangerLimit) %>"
                  class="w-full border rounded-lg px-4 py-3"
                  required
                >
              </div>
            </div>
            <p class="text-sm text-slate-500 mt-2">
              Current danger threshold: <strong><%= formatTime(user.dangerLimit) %></strong>
            </p>
          </div>

          <div>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition">
              Save Preferences
            </button>
          </div>
        </form>
      </div>

      <div class="bg-white rounded-2xl shadow border border-slate-200 p-6">
        <h2 class="text-2xl font-bold mb-6">Change Password</h2>

        <form action="/profile-settings/password" method="POST" class="grid gap-4">
          <div>
            <label class="block mb-2 font-medium">Current Password</label>
            <input
              type="password"
              name="currentPassword"
              class="w-full border rounded-lg px-4 py-3"
              required
            >
          </div>

          <div>
            <label class="block mb-2 font-medium">New Password</label>
            <input
              type="password"
              name="newPassword"
              class="w-full border rounded-lg px-4 py-3"
              required
            >
          </div>

          <div>
            <label class="block mb-2 font-medium">Confirm New Password</label>
            <input
              type="password"
              name="confirmNewPassword"
              class="w-full border rounded-lg px-4 py-3"
              required
            >
          </div>

          <div>
            <button type="submit" class="bg-slate-900 hover:bg-slate-700 text-white px-6 py-3 rounded-lg font-semibold transition">
              Update Password
            </button>
          </div>
        </form>
      </div>
    </div>

    <div class="mt-8 bg-white rounded-2xl shadow border border-slate-200 p-6">
      <h2 class="text-2xl font-bold mb-4">How Your Limits Work</h2>
      <div class="grid md:grid-cols-3 gap-4">
        <div class="p-4 rounded-xl bg-yellow-50 border border-yellow-200">
          <h3 class="font-bold text-yellow-700 mb-2">Warning Threshold</h3>
          <p class="text-sm text-slate-600">
            You receive a warning when your usage reaches <strong><%= formatTime(user.warningLimit) %></strong>.
          </p>
        </div>

        <div class="p-4 rounded-xl bg-red-50 border border-red-200">
          <h3 class="font-bold text-red-700 mb-2">Danger Threshold</h3>
          <p class="text-sm text-slate-600">
            You enter the danger zone when your usage reaches or crosses <strong><%= formatTime(user.dangerLimit) %></strong>.
          </p>
        </div>

        <div class="p-4 rounded-xl bg-blue-50 border border-blue-200">
          <h3 class="font-bold text-blue-700 mb-2">Personalized Limits</h3>
          <p class="text-sm text-slate-600">
            You can set thresholds in both hours and minutes for more precise control.
          </p>
        </div>
      </div>
    </div>
  </div>

  <%- include("../partials/footer") %>

</body>
</html>