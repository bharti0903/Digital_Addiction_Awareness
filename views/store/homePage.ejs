<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Screen Time Overview</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gradient-to-br from-blue-50 via-white to-indigo-50 min-h-screen text-slate-800 font-sans">

  <%- include("../partials/navbar") %>

  <%
    function formatTime(value) {
      const h = Math.floor(value || 0);
      const m = Math.round(((value || 0) % 1) * 60);
      return `${h}h ${m}m`;
    }
  %>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-8">
    <section class="mb-10">
      <div class="bg-white rounded-3xl shadow-lg border border-blue-50 p-8 sm:p-10">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
          <div>
            <h2 class="text-3xl sm:text-4xl font-bold text-blue-950 mb-3">
              Screen Time Overview
            </h2>
            <p class="text-slate-600 text-lg max-w-2xl">
              Track your daily usage, understand your habits, and stay within healthy limits.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full lg:w-auto">
            <a href="/track-screen-time" class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-6 py-4 rounded-2xl font-bold hover:shadow-lg hover:shadow-blue-200 transition text-center">
              <i class="fas fa-clock mr-2"></i>
              Activity Tracking
            </a>
            <a href="/weekly-report" class="bg-white border border-blue-200 text-blue-700 px-6 py-4 rounded-2xl font-bold hover:bg-blue-50 transition text-center">
              <i class="fas fa-chart-line mr-2"></i>
              Usage Analytics
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-6 gap-6 mb-10">
      <div class="bg-white rounded-2xl shadow border border-blue-50 p-6">
        <h3 class="text-slate-600 font-semibold mb-2">Today’s Usage</h3>
        <p class="text-3xl font-bold text-blue-700"><%= todayTotal %> hrs</p>
      </div>

      <div class="bg-white rounded-2xl shadow border border-blue-50 p-6">
        <h3 class="text-slate-600 font-semibold mb-2">Time Left</h3>
        <p class="text-3xl font-bold text-green-700"><%= timeLeft %> hrs</p>
      </div>

      <div class="bg-white rounded-2xl shadow border border-blue-50 p-6">
        <h3 class="text-slate-600 font-semibold mb-2">Most Used</h3>
        <p class="text-2xl font-bold text-indigo-700"><%= mostUsedCategory %></p>
      </div>

      <div class="bg-white rounded-2xl shadow border border-blue-50 p-6">
        <h3 class="text-slate-600 font-semibold mb-2">Score</h3>
        <p class="text-3xl font-bold text-green-700"><%= productivityScore %>/100</p>
      </div>

      <div class="bg-white rounded-2xl shadow border border-blue-50 p-6">
        <h3 class="text-slate-600 font-semibold mb-2">Status</h3>
        <p class="text-2xl font-bold <%= usageStatus === 'Healthy' ? 'text-green-600' : usageStatus === 'Approaching Limit' ? 'text-yellow-600' : 'text-red-600' %>">
          <%= usageStatus %>
        </p>
      </div>

      <div class="bg-white rounded-2xl shadow border border-blue-50 p-6">
        <h3 class="text-slate-600 font-semibold mb-2">Streak</h3>
        <p class="text-3xl font-bold text-orange-600"><%= currentStreak %> 🔥</p>
      </div>
    </section>

    <section class="mb-10">
      <div class="bg-white rounded-3xl shadow border border-blue-50 p-6 sm:p-8">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-blue-950">Daily Limit Progress</h2>
          <span class="text-sm font-semibold text-slate-600"><%= todayTotal %> / <%= dailyLimit %> hrs</span>
        </div>

        <div class="w-full bg-slate-200 rounded-full h-4 overflow-hidden">
          <div
            class="h-4 rounded-full <%= usageStatus === 'Healthy' ? 'bg-green-500' : usageStatus === 'Approaching Limit' ? 'bg-yellow-500' : 'bg-red-500' %>"
            style="width:<%= progressPercent %>%"
          ></div>
        </div>

        <div class="flex flex-wrap gap-3 mt-4 text-sm">
          <span class="px-3 py-1 rounded-full bg-yellow-100 text-yellow-700 font-semibold">
            Warning: <%= formatTime(warningLimit) %>
          </span>
          <span class="px-3 py-1 rounded-full bg-red-100 text-red-700 font-semibold">
            Danger: <%= formatTime(dangerLimit) %>
          </span>
          <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 font-semibold">
            Best Streak: <%= bestStreak %> 🏆
          </span>
        </div>
      </div>
    </section>

    <section class="mb-10">
      <div class="bg-white rounded-3xl shadow border border-blue-50 p-6 sm:p-8">
        <h2 class="text-2xl font-bold text-blue-950 mb-6">Today by Category</h2>
        <div class="h-80">
          <canvas id="dashboardChart"></canvas>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
      <div class="lg:col-span-2 bg-white rounded-3xl shadow border border-blue-50 p-6 sm:p-8">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-bold text-blue-950">Recent Activity</h2>
          <a href="/track-screen-time" class="text-blue-600 hover:text-blue-700 font-semibold transition">
            Open Activity Tracking
          </a>
        </div>

        <% if (recentEntries && recentEntries.length > 0) { %>
          <div class="space-y-4">
            <% recentEntries.forEach(entry => { %>
              <div class="border border-slate-200 rounded-2xl p-5 hover:shadow-md transition bg-slate-50/70">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-2">
                  <div>
                    <h3 class="font-bold text-slate-800"><%= entry.category %></h3>
                    <p class="text-sm text-slate-500"><%= new Date(entry.date).toLocaleDateString() %></p>
                  </div>
                  <div class="text-right">
                    <p class="text-xl font-bold text-blue-700"><%= entry.hours %> hrs</p>
                  </div>
                </div>
                <div class="mt-2 text-sm text-slate-600">
                  <strong>Notes:</strong> <%= entry.notes && entry.notes.trim() ? entry.notes : "No notes added" %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-slate-500">No recent activity found.</p>
        <% } %>
      </div>

      <div class="bg-white rounded-3xl shadow border border-blue-50 p-6 sm:p-8">
        <h2 class="text-2xl font-bold text-blue-950 mb-6">Quick Access</h2>

        <div class="space-y-4">
          <a href="/track-screen-time" class="block p-4 rounded-2xl border border-slate-200 hover:border-blue-300 hover:bg-blue-50 transition font-semibold">
            Activity Tracking
          </a>
          <a href="/weekly-report" class="block p-4 rounded-2xl border border-slate-200 hover:border-indigo-300 hover:bg-indigo-50 transition font-semibold">
            Usage Analytics
          </a>
          <a href="/smart-alerts" class="block p-4 rounded-2xl border border-slate-200 hover:border-yellow-300 hover:bg-yellow-50 transition font-semibold">
            Limits & Notifications
          </a>
          <a href="/detox-challenges" class="block p-4 rounded-2xl border border-slate-200 hover:border-green-300 hover:bg-green-50 transition font-semibold">
            Goals & Habits
          </a>
          <a href="/profile-settings" class="block p-4 rounded-2xl border border-slate-200 hover:border-slate-400 hover:bg-slate-50 transition font-semibold">
            Limits & Preferences
          </a>
        </div>
      </div>
    </section>
  </main>

  <%- include("../partials/footer") %>
  <%- include("../partials/toast", { userId }) %>

  <script id="dashboard-chart-labels" type="application/json"><%- JSON.stringify(chartLabels || []) %></script>
  <script id="dashboard-chart-data" type="application/json"><%- JSON.stringify(chartData || []) %></script>

  <script>
    socket.on("screenTimeUpdated", function () {
      window.location.reload();
    });

    const labelsEl = document.getElementById("dashboard-chart-labels");
    const dataEl = document.getElementById("dashboard-chart-data");
    const dashboardCtx = document.getElementById("dashboardChart");

    let parsedLabels = [];
    let parsedData = [];

    try {
      parsedLabels = JSON.parse(labelsEl.textContent);
      parsedData = JSON.parse(dataEl.textContent);
    } catch (error) {
      console.error("Chart data parse error:", error);
    }

    if (dashboardCtx) {
      new Chart(dashboardCtx, {
        type: "doughnut",
        data: {
          labels: parsedLabels,
          datasets: [
            {
              label: "Hours",
              data: parsedData,
              borderWidth: 1
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false
        }
      });
    }
  </script>
</body>
</html>