<div id="toastContainer" class="fixed top-20 right-4 z-[9999] space-y-3"></div>

<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const currentUserId = "<%= typeof userId !== 'undefined' ? userId : '' %>";

  if (currentUserId) {
    socket.emit("joinUserRoom", currentUserId);
  }

  function createToast(message, type) {
    const toastContainer = document.getElementById("toastContainer");
    if (!toastContainer) return;

    const toast = document.createElement("div");

    let bgClass = "bg-blue-600";
    let icon = "ℹ️";

    if (type === "warning") {
      bgClass = "bg-yellow-500";
      icon = "⚠️";
    } else if (type === "danger") {
      bgClass = "bg-red-600";
      icon = "🚨";
    } else if (type === "info") {
      bgClass = "bg-blue-600";
      icon = "ℹ️";
    }

    toast.className = `${bgClass} text-white px-5 py-4 rounded-xl shadow-lg max-w-sm animate-pulse`;
    toast.innerHTML = `
      <div class="flex items-start gap-3">
        <div class="text-xl">${icon}</div>
        <div>
          <p class="font-bold capitalize">${type}</p>
          <p class="text-sm mt-1">${message}</p>
        </div>
      </div>
    `;

    toastContainer.appendChild(toast);

    setTimeout(() => {
      toast.remove();
    }, 4500);
  }

  socket.on("newAlert", function (alert) {
    createToast(alert.message, alert.type);
  });
</script>